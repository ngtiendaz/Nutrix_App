@startuml
skinparam style strictuml
skinparam DefaultFontSize 14
skinparam ActorFontSize 16
skinparam ParticipantFontSize 14
skinparam monochrome true
skinparam shadowing false
skinparam ParticipantPadding 20
skinparam BoxPadding 10

actor "Quản trị viên" as Admin
boundary "GD_QuanLyHoatDong" as Boundary
control "Ctrl_HoatDong" as Control
entity "Database" as DB

Admin -> Boundary : 1: Chọn hoạt động & chọn "Xóa"
activate Boundary
Boundary -> Control : 2: Yêu cầu xác nhận xóa
activate Control
Control --> Boundary : 3: Hiển thị hộp thoại xác nhận
deactivate Control
Boundary --> Admin : 4: Yêu cầu xác nhận (Đồng ý/Hủy)

alt Người dùng chọn "Đồng ý"
    Admin -> Boundary : 5: Nhấn "Đồng ý"
    activate Boundary
    Boundary -> Control : 6: Gửi lệnh xóa hoạt động
    activate Control
    Control -> DB : 7: Thực hiện xóa khỏi CSDL
    activate DB
    DB --> Control : 8: Xác nhận thành công
    deactivate DB
    Control --> Boundary : 9: Phản hồi thành công
    Boundary --> Admin : 10: Thông báo "Đã xóa hoạt động"
    deactivate Control
    deactivate Boundary
else Người dùng chọn "Hủy"
    Admin -> Boundary : 5: Nhấn "Hủy"
    activate Boundary
    Boundary --> Admin : 6: Thoát, không thay đổi CSDL
    deactivate Boundary
end
@enduml