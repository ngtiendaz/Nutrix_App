@startuml
skinparam Style robustness
autonumber
skinparam BackgroundColor white
skinparam ParticipantPadding 20
skinparam BoxPadding 10

actor "Người dùng" as User
boundary "GD_NhatKy\n(DiaryView)" as GD_Diary
boundary "GD_TuyChon\n(OptionDetail)" as GD_Option
boundary "GD_PhanTich\n(FoodAnalysisView)" as GD_Analysis
control "Ctrl_PhanTich\n(FoodAnalysisViewModel)" as Ctrl_Analysis
control "Ctrl_DichVuAI\n(Vision & Edamam)" as Ctrl_AI
entity "Data_NhatKy\n(FirebaseService)" as Data_FB

' --- BẮT ĐẦU LUỒNG ---
User -> GD_Diary : Nhấn nút (+) Thêm món
activate GD_Diary
GD_Diary -> GD_Option : Hiển thị bảng chọn nguồn (Sheet)
deactivate GD_Diary

activate GD_Option
User -> GD_Option : Chọn Camera / Thư viện ảnh
GD_Option -> GD_Option : Mở ImagePicker hệ thống
User -> GD_Option : Chụp hoặc chọn ảnh món ăn

GD_Option -> GD_Analysis : Khởi tạo với ảnh đã chọn
deactivate GD_Option

activate GD_Analysis
GD_Analysis -> Ctrl_Analysis : startAnalysis() (qua .task)
activate Ctrl_Analysis

' --- XỬ LÝ AI ---
Ctrl_Analysis -> Ctrl_AI : analyzeImage(uiImage)
activate Ctrl_AI
Ctrl_AI --> Ctrl_Analysis : Trả về nhãn nhận diện (Labels)
deactivate Ctrl_AI

Ctrl_Analysis -> Ctrl_AI : fetchNutrition(foodName)
activate Ctrl_AI
Ctrl_AI --> Ctrl_Analysis : Trả về Calories, Protein, Carbs, Fats...
deactivate Ctrl_AI

Ctrl_Analysis --> GD_Analysis : Cập nhật UI hiển thị thông tin món ăn
deactivate Ctrl_Analysis

' --- LƯU DỮ LIỆU ---
User -> GD_Analysis : Điều chỉnh khối lượng & Nhấn "Lưu nhật ký"
activate Ctrl_Analysis

GD_Analysis -> Ctrl_Analysis : saveFood()
Ctrl_Analysis -> Data_FB : uploadFoodImage(image)
activate Data_FB
Data_FB --> Ctrl_Analysis : Trả về URL ảnh từ Storage
deactivate Data_FB

Ctrl_Analysis -> Data_FB : addFoodToMeal(userId, mealType, food)
activate Data_FB
Data_FB -> Data_FB : updateMeal() hoặc createNewMeal()
Data_FB -> Data_FB : updateDailySummary() (Cập nhật tổng dinh dưỡng ngày)
Data_FB --> Ctrl_Analysis : Result.success
deactivate Data_FB

Ctrl_Analysis --> GD_Analysis : Gọi onSaveSuccess() callback
deactivate Ctrl_Analysis

GD_Analysis -> GD_Diary : dismiss() & diaryViewModel.refreshData()
deactivate GD_Analysis

activate GD_Diary
GD_Diary -> Data_FB : fetchDailyData(for: selectedDate)
activate Data_FB
Data_FB --> GD_Diary : Trả về danh sách món ăn mới
deactivate Data_FB
GD_Diary --> User : Hiển thị món ăn mới trong danh sách nhật ký
deactivate GD_Diary

@enduml